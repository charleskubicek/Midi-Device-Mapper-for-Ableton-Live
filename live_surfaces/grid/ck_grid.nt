controller: controller_grid.nt
ableton_dir: /Applications/Ableton Live 12 Suite.app
#ableton_dir: /Applications/Ableton Live 12 Beta.app
parameter_mappings_file: ../../data/custom_device_mappings.json

remote_on: false
hud: on

mode-button:
    button: grid-2:4::1
    type: shift
modes:
    -
        name: main_mode
        on_color: red_low
        mappings:
            -
                type: device
                track: selected
                device: selected
                mappings:
                    encoders:
                        range: grid-1:1-16
                        slots: 1-16
#                    on-off: grid-2:3
                    button:
                        range: grid-2:2::1-4
                        slots: 1-4
            -
                type: mixer
                track: selected
                mappings:
                    mute: grid-2:1
                    solo: grid-2:2
#                    arm: grid-2:4::2
            -
                type: functions
                mappings:
                    iterate_midi_pattern: grid-2:1::4
                    back8: grid-2:1::3
#                    update_colors: grid-2:6
#                    press_rack_random_button: grid-2:3::1
                    hud_toggle: grid-2:3::1
            -
                type: device-nav
                mappings:
                    left: grid-2:4::3
                    right: grid-2:4::4
                    first-last: grid-2:3::4
            -
                type: track-nav
                mappings:
                    left: grid-2:3::2
                    right: grid-2:3::3, grid-2:4::2
    -
        name: shift_mode
        on_color: green_full
        mappings:
            -
                type: mixer
                track: selected
                mappings:
                    volume: grid-1:4
                    pan: grid-1:3
                    sends: grid-1:5-8,grid-1:9-12
            -
                type: device
                track: selected
                device: selected
                mappings:
                    button:
                        range: grid-2:1-12
                        slots: 5-16
            -
                type: functions
                mappings:
                    press_rack_random_button: grid-2:4::2
            -
                type: parameter-pager
                encoders:
                    inc: grid-2:4::4
                    dec: grid-2:4::3