controller: controller_grid.nt
ableton_dir: /Applications/Ableton Live 12 Suite.app
#ableton_dir: /Applications/Ableton Live 12 Beta.app
parameter_mappings_file: ../../data/custom_device_mappings.json

# smart-zoning (grid-po16-synth-surface-plan): each enrolled synth (Wavetable,
# Drift, Operator, Analog) gets the fixed 32-pot / 16-button zone layout as
# page 1; non-enrolled devices fall back to BOB/banks exactly as before.
smart-zoning: on

# grid_led (grid-po16-synth-surface-plan §F): stream a dense 48-slot RGB LED
# frame (hue = zone colour, brightness = live value) to the Grid's MIDI RX on
# every device-focus burst. Grid-side Lua: live_surfaces/grid/grid_led_handler.lua
# Turned OFF for now — re-enable by uncommenting the feedback block below.
#feedback:
#    -
#        type: grid_led

remote_on: false

# hud — what the HUD shows (uncomment exactly one):
hud: on
# on = every mapped cell shows its label (dials + buttons)
#hud: device_only   — only the focused device's parameters; other cells blank
#hud: off           — HUD disabled entirely

# show-hud-on — when the HUD appears (uncomment exactly one):
show-hud-on: summon
# summon = hidden by default; only the hud_toggle button or a controller device-nav shows it, and it auto-hides on any non-device view (clip view, browser, Session↔Arranger)
#show-hud-on: selection        — follow Live's selected device; HUD shows on any device change (mouse or controller)
#show-hud-on: controller-nav   — only a controller device-nav action shows the HUD; mouse/track selection stays hidden

mode-button:
    button: grid-4:4::1
    type: shift
modes:
    -
        name: main_mode
        on_color: red_low
        mappings:
            -
                type: device
                track: selected
                device: selected
                mappings:
                    encoder-list:
                        -
                            range: grid-2:1-16
                            slots: 1-16
                        -
                            range: grid-3:1-16
                            slots: 17-32
                    button:
                        range: grid-1:1-16
                        slots: 1-16
                    on-off: grid-4:3
                    # Drum-rack precedence (ai-coding/plans/drum_rack.md): inert
                    # unless the focused device is a drum rack, then these share
                    # controls with the switch/macro roles above and win.
                    # MAIN mode: grid-1 buttons SELECT the pad (which drum the
                    # sequencer edits); hold shift to edit that pad's steps.
                    # grid-2 knobs -> per-step velocity. Pad audition (sound on
                    # press) is the deferred spike seam.
                    pads:
                        range: grid-1:1-16
                    velocities:
                        range: grid-2:1-16
            -
                type: mixer
                track: selected
                mappings:
                    mute: grid-4:1
                    solo: grid-4:2
            -
                type: functions
                mappings:
                    toggle_mono_on_master: grid-4:1::4
                    hud_toggle: grid-4:4::2
            -
                type: device-nav
                mappings:
                    left:  grid-4:4::3
                    right: grid-4:4::4
                    first-last: grid-4:3::2
            -
                type: track-nav
                mappings:
                    left:  grid-4:3::3
                    right: grid-4:3::4
            -
                type: functions
                mappings:
                    back8: grid-4:2::3
                    fwd8:  grid-4:2::4
                    move_loop_left : grid-4:2::1
                    move_loop_right: grid-4:2::2
                    move_playhead_to_loop_start: grid-4:3::1
    -
        name: shift_mode
        on_color: green_full
        mappings:
            -
                type: mixer
                track: selected
                mappings:
                    volume: grid-3:4
                    pan: grid-3:3
                    sends: grid-3:5-8,grid-3:9-12
            -
                type: device
                track: selected
                device: selected
                mappings:
                    button:
                        range: grid-1:1-16
                        slots: 17-32
                    encoders:
                        range: grid-2:1-16
                        slots: 33-48
                    # Drum-rack precedence: SHIFT mode edits the selected pad's
                    # pattern — grid-1 buttons -> 16-step sequencer, grid-2 knobs
                    # -> per-step velocity. The pad is chosen in main mode (pads
                    # above); selection persists across the mode switch.
                    sequencer:
                        range: grid-1:1-16
                    velocities:
                        range: grid-2:1-16
            -
                type: functions
                mappings:
                    # R3C1 in the design. NOT grid-4:4::1 — that is the shift
                    # mode-button itself; binding a function there steals its
                    # note-off and wedges the FSM in shift mode.
                    press_rack_random_button: grid-4:3::1
                    halve_loop_length:  grid-4:2::1
                    double_loop_length: grid-4:2::2
                    move_device_left:   grid-4:2::3
                    move_device_right:  grid-4:2::4
                    # Top row (design R1): record / bounce ops.
                    create_audio_track_taking_input_from_selected_track: grid-4:1::1
                    record_audio_resample:                               grid-4:1::2
                    record_midi_from_track_to_new_track:                 grid-4:1::3
                    selected_audio_to_simpler_in_new_track:              grid-4:1::4
                    # R3C3/R3C4: jump 3 tracks at a time.
                    track_nav_left_x3:  grid-4:3::3
                    track_nav_right_x3: grid-4:3::4
            -
                type: parameter-pager
                encoders:
                    inc: grid-4:4::4
                    dec: grid-4:4::3