controller: controller_grid.nt
ableton_dir: /Applications/Ableton Live 12 Suite.app
#ableton_dir: /Applications/Ableton Live 12 Beta.app
parameter_mappings_file: ../../data/custom_device_mappings.json

remote_on: false
hud: device_only

mode-button:
    button: grid-2:4::1
    type: shift
modes:
    -
        name: main_mode
        on_color: red_low
        mappings:
            -
                type: device
                track: selected
                device: selected
                mappings:
                    encoders:
                        range: grid-1:1-16
                        slots: 1-16
                    on-off: grid-2:3
            -
                type: mixer
                track: selected
                mappings:
                    mute: grid-2:1
                    solo: grid-2:2
            -
                type: functions
                mappings:
                    iterate_midi_pattern: grid-2:4
                    back8: grid-2:5
                    update_colors: grid-2:6
                    press_rack_random_button: grid-2:9
            -
                type: device-nav
                mappings:
                    left: grid-2:15
                    right: grid-2:16
                    first-last: grid-2:12
            -
                type: track-nav
                mappings:
                    left: grid-2:10
                    right: grid-2:11, grid-2:14
#                    right: grid-1:14  # to bind a 2nd button: right: grid-2:11, grid-1:14 (pick a FREE control — grid-1:14 is device encoder slot 14)
    -
        name: shift_mode
        on_color: green_full
        mappings:
            -
                type: mixer
                track: selected
                mappings:
                    volume: grid-1:4
#                    pan: row-2:8
#                    sends: row-1:5-7,row-2:5-7
