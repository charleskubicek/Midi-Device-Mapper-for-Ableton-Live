controller: controller_grid.nt
ableton_dir: /Applications/Ableton Live 12 Suite.app
#ableton_dir: /Applications/Ableton Live 12 Beta.app
parameter_mappings_file: ../../data/custom_device_mappings.json

# smart-zoning (grid-po16-synth-surface-plan): each enrolled synth (Wavetable,
# Drift, Operator, Analog) gets the fixed 32-pot / 16-button zone layout as
# page 1; non-enrolled devices fall back to BOB/banks exactly as before.
smart-zoning: on

# grid_led (grid-po16-synth-surface-plan §F): stream a dense 48-slot RGB LED
# frame (hue = zone colour, brightness = live value) to the Grid's MIDI RX on
# every device-focus burst. Grid-side Lua: live_surfaces/grid/grid_led_handler.lua
# Turned OFF for now — re-enable by uncommenting the feedback block below.
#feedback:
#    -
#        type: grid_led

remote_on: false

# hud — what the HUD shows (uncomment exactly one):
hud: on
# on = every mapped cell shows its label (dials + buttons)
#hud: device_only   — only the focused device's parameters; other cells blank
#hud: off           — HUD disabled entirely

# show-hud-on — when the HUD appears (uncomment exactly one):
show-hud-on: selection
# selection = follow Live's selected device; HUD shows on any device change (mouse or controller)
#show-hud-on: controller-nav   — only a controller device-nav action shows the HUD; mouse/track selection stays hidden

mode-button:
    button: grid-4:4::1
    type: shift
modes:
    -
        name: main_mode
        on_color: red_low
        mappings:
            -
                type: device
                track: selected
                device: selected
                mappings:
                    encoder-list:
                        -
                            range: grid-2:1-16
                            slots: 1-16
                        -
                            range: grid-3:1-16
                            slots: 17-32
                    button:
                        range: grid-1:1-16
                        slots: 1-16
            -
                type: mixer
                track: selected
                mappings:
                    mute: grid-4:1
                    solo: grid-4:2
#                    arm: grid-4:4::2
            -
                type: functions
                mappings:
                    iterate_midi_pattern: grid-4:1::4
                    back8: grid-4:1::3
#                    update_colors: grid-4:6
#                    press_rack_random_button: grid-4:3::1
                    hud_toggle: grid-4:4::2
            -
                type: device-nav
                mappings:
                    left: grid-4:4::3
                    right: grid-4:4::4
#                    first-last: grid-4:3::4
#            -
#                type: track-nav
#                mappings:
#                    left: grid-4:3::2
#                    right: grid-4:3::3, grid-4:4::2
    -
        name: shift_mode
        on_color: green_full
        mappings:
            -
                type: mixer
                track: selected
                mappings:
                    volume: grid-3:4
                    pan: grid-3:3
                    sends: grid-3:5-8,grid-3:9-12
            -
                type: device
                track: selected
                device: selected
                mappings:
                    button:
                        range: grid-1:1-16
                        slots: 17-32
                    encoders:
                        range: grid-2:1-16
                        slots: 33-48
            -
                type: functions
                mappings:
                    press_rack_random_button: grid-4:4::2
            -
                type: parameter-pager
                encoders:
                    inc: grid-4:4::4
                    dec: grid-4:4::3