controller: controller_lc.nt
ableton_dir: /Applications/Ableton Live 12 Suite.app
parameter_mappings_file: ../../data/custom_device_mappings.json
#ableton_dir: /Applications/Ableton Live 12 Beta.app

remote_on: true
mode-button:
    button: row-3:1
    type: shift
modes:
    -
        name: main_mode
        on_color: red_low
        mappings:
            -
                type: device
                track: selected
                device: selected
                mappings:
                    encoder-list:
                        -
                            range: row-1:1-8
                            slots: 1-8
                        -
                            range: row-2:1-8
                            slots: 9-16
                    on-off: row-3:4 toggle
            -
                type: mixer
                track: selected
                mappings:
                    mute: row-3:2
                    solo: row-3:3
            -
                type: functions
                mappings:
                    iterate_midi_pattern: row-3:5
                    back8: row-3:6
                    update_colors: row-3:7
                    press_rack_random_button: row-3:8
            -
                type: device-nav
                mappings:
                    left: row-5:1
                    right: row-5:2
    #               first-last: row-3:8
            -
                type: track-nav
                mappings:
                    left: row-4:1
                    right: row-4:2
    -
        name: shift_mode
        on_color: green_full
        mappings:
            -
                type: mixer
                track: selected
                mappings:
                    volume: row-1:8
                    pan: row-2:8
                    sends: row-1:5-7,row-2:5-7
    #               arm: row-3:3
    #        -
    #            type: device
    #            track: master
    #            device: Mono
    #            ranges:
    #                -
    #                    range: row-3:2 toggle
    #                    parameters: 0
            -
                type: device
                track: selected
                device: selected
                mappings:
                    switch1: row-3:5
                    switch2: row-3:6
                    switch3: row-3:7
                    switch4: row-3:8
            -
                type: functions
                mappings:
                    record_midi_from_track_to_new_track: row-3:2 toggle
                    create_audio_track_taking_input_from_selected_track: row-3:3 toggle
                    selected_audio_to_simpler_in_new_track: row-3:4
#                    sequencer_random_notes: row-3:5
#                    sequencer_random_velocity: row-3:6
#                    sequencer_random_length: row-3:7
#                    sequencer_shift_right: row-3:8

    #                shift_clip_notes_left: row-4:1
    #                shift_clip_notes_right: row-4:2
                    clip_extend: row-5:2
                    clip_delete_end: row-5:1
            -
                type: parameter-pager
                encoders:
                    inc: row-4:2
                    dec: row-4:1