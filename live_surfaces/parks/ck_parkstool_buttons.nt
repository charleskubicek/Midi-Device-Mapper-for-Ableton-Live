# Cut-down parks surface: exports the parks buttons to the HUD. Generated as
# the FORWARDER half of the lc_parks composition (see
# ../lc_parks/lc_parks.nt): its HudClient is retargeted at lc_parks' region
# port, so it forwards its resolved region to the compositor rather than to the
# HUD directly. Load THIS surface in Ableton on the parks MIDI port.
#
# It is an ordinary device mapping — buttons reflect the same globally-focused
# device's parameters as launch_control, updating live on device change.

controller: parks_controller.nt
ableton_dir: /Applications/Ableton Live 12 Suite.app
parameter_mappings_file: ../../data/custom_device_mappings.json
remote_on: false

# hud — what the HUD shows (uncomment exactly one):
hud: on
# on = every mapped cell shows its label (dials + buttons)
#hud: device_only   — only the focused device's parameters; other cells blank
#hud: off           — HUD disabled entirely

# show-hud-on — when the HUD appears (uncomment exactly one):
# NOTE: must stay 'selection' here — this forwarder has no device-nav control of
# its own, so under controller-nav it would never burst and its HUD region would
# stay empty.
show-hud-on: selection
# selection = follow Live's selected device; HUD shows on any device change (mouse or controller)
#show-hud-on: controller-nav   — only a controller device-nav action shows the HUD; mouse/track selection stays hidden

mappings:
    -
        type: device
        track: selected
        device: selected
        mappings:
            button-list:
                -
                    range: row-1:1-2
                    slots: 1-2
                -
                    range: row-2:1-2
                    slots: 3-4