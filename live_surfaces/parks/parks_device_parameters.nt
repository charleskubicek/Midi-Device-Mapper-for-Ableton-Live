custom-parameter-mappings:
    -
        device-name: SQ Sequencer
        # no other device will be able to use these buttons
        exclusive: true

        # should relate to encoder-list
        parameter-groups:
            -
                name: buttons1
                parameters:
                    - ScramblePitch
                    - RandPitch
                    - ScrambleVel
                    - VelRandom
                    - ScrambleOct
                    - RandOct
                    - RandLength
            -
                name: buttons2
                parameters:
                    - ScrambleLength
                    - SQMin
                    - SQMax
                    - ShiftLeft
                    - ShiftRight
                    - ShiftUp
                    - ShiftDown
