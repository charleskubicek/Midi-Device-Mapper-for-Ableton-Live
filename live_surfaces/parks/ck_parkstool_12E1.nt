controller: parks_controller.nt
ableton_dir: /Applications/Ableton Live 12 Suite.app
#ableton_dir: /Applications/Ableton Live 12 Beta.app


mappings:
    -
        type: device
        track: selected
        device: selected
        parameter-mappings-file: parks_device_parameters.nt
        mappings:
            encoder-list:
                -
                    name: sliders
                    range: row-1:1-8
                    parameters: 17-24
                -
                    name: buttons1
                    range: row-2:1-8
                    parameters: 40-49
                -
                    name: buttons2
                    range: row-3:1-8
                    parameters: 50-59

